generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Departamento {
  id      Int      @id @default(autoincrement())
  nombre  String
  puestos Puesto[]
  usuarios Usuario[]
}

model Usuario {
  id             Int          @id @default(autoincrement())
  email          String       @unique
  password       String
  nombre         String
  role           String       @default("usuario")
  departamentoId Int?
  departamento   Departamento? @relation(fields: [departamentoId], references: [id])
  puestos        Puesto[]
  empleado       Empleado?
  createdAt      DateTime     @default(now())
}

model Puesto {
  id                Int               @id @default(autoincrement())
  codigo            String            @default("")
  nombre            String
  usuarioId         Int?
  usuario           Usuario?          @relation(fields: [usuarioId], references: [id])
  objetivo          String            @default("")
  horario           String            @default("Lun-Vie 9:00-18:00 / Sab 9:00-13:00")
  escolaridad       String            @default("Licenciatura")
  experiencia       String            @default("")
  edadMin           Int               @default(25)
  edadMax           Int               @default(55)
  reportaA          String            @default("")
  supervisaA        String            @default("")
  tiempoAdaptacion  String            @default("3 meses")
  periodicidad      String            @default("Mensual")
  herramientas      String            @default("")
  formacion         String            @default("")
  competencias      String            @default("")
  titular           String            @default("")
  estado            String            @default("pendiente")
  // Supervisión
  tienePersonal           Boolean  @default(false)
  numPersonasACargo       String   @default("")
  comoSupervisa           String   @default("")
  comoAudita              String   @default("")
  comoEvalua              String   @default("")
  autoridadSobre          String   @default("")
  // Relaciones
  internoConQuien         String   @default("")
  externoConQuien         String   @default("")
  // Documentos y decisiones
  documentosQueGenera     String   @default("")
  decisionesIndependientes String  @default("")
  decisionesConAutorizacion String @default("")
  // Situaciones
  tareasNoCorresponden    String   @default("")
  tareasQueNadieHace      String   @default("")
  problemasFrecuentes     String   @default("")
  comoMideSuTrabajo       String   @default("")
  // Admin
  adminNotas              String   @default("")
  departamentoId    Int?
  departamento      Departamento?     @relation(fields: [departamentoId], references: [id])
  responsabilidades Responsabilidad[]
  kpis              Kpi[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model Responsabilidad {
  id          Int     @id @default(autoincrement())
  nombre      String
  descripcion String  @default("")
  tiempoHoras Float   @default(1)
  recurrencia String  @default("Diaria")
  nivel       String  @default("Medio")
  orden       Int     @default(0)
  estado      String  @default("pendiente") // pendiente | confirmada
  origen      String  @default("")           // de dónde vino si está en el banco
  puestoId    Int?
  puesto      Puesto? @relation(fields: [puestoId], references: [id], onDelete: Cascade)
}

model Kpi {
  id         Int      @id @default(autoincrement())
  area       String
  metrica    String
  meta       String
  actual     String   @default("")
  unidad     String   @default("%")
  frecuencia String   @default("Mensual")
  estado     String   @default("pendiente")
  puestoId   Int
  puesto     Puesto   @relation(fields: [puestoId], references: [id], onDelete: Cascade)
  updatedAt  DateTime @updatedAt
}

model Queja {
  id        Int      @id @default(autoincrement())
  tipo      String   @default("queja") // queja | sugerencia | reconocimiento
  area      String   @default("")
  mensaje   String
  leida     Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Empleado {
  id           Int          @id @default(autoincrement())
  nombre       String
  puesto       String       @default("")
  area         String       @default("")
  tipo         String       @default("empleado") // empleado | proveedor
  factura      Boolean      @default(false)       // si emite factura
  fechaIngreso DateTime?
  sueldoActual Float        @default(0)
  bonoDespensa Float        @default(0)
  bonoGasolina Float        @default(0)
  correo       String       @default("")
  telefono     String       @default("")
  notas          String       @default("")
  activo         Boolean      @default(true)
  diasVacaciones Int          @default(12)
  diasExtra      Int          @default(0)   // días de cortesía otorgados por la empresa
  horaEntrada    String       @default("09:00")
  usuarioId      Int?         @unique
  usuario        Usuario?     @relation(fields: [usuarioId], references: [id])
  incrementos    Incremento[]
  vacaciones     Vacacion[]
  asistencias    Asistencia[]
  createdAt      DateTime     @default(now())
}

model Asistencia {
  id          Int      @id @default(autoincrement())
  empleadoId  Int
  empleado    Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  fecha       DateTime
  estado      String   @default("a_tiempo") // a_tiempo | retardo | falta | justificado
  horaLlegada String   @default("")
  horaSalida  String   @default("")
  comidaInicio String  @default("")
  comidaFin   String   @default("")
  ipLlegada   String   @default("")
  ipSalida    String   @default("")
  origen      String   @default("admin") // admin | empleado (autoregistro)
  verificado  Boolean  @default(false)   // RH revisó/confirmó el registro
  nota        String   @default("")

  @@unique([empleadoId, fecha])
}

model Config {
  id            Int    @id @default(autoincrement())
  ipOficina     String @default("")
  minutosComida Int    @default(60)
}

model Comunicado {
  id        Int      @id @default(autoincrement())
  titulo    String
  mensaje   String
  fijado    Boolean  @default(false)
  autor     String   @default("")
  createdAt DateTime @default(now())
}

model Notificacion {
  id        Int      @id @default(autoincrement())
  tipo      String   @default("info") // puesto | buzon | vacaciones | info
  titulo    String
  mensaje   String   @default("")
  link      String   @default("")
  leida     Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Vacacion {
  id          Int      @id @default(autoincrement())
  empleadoId  Int
  empleado    Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  fechaInicio DateTime
  fechaFin    DateTime
  dias        Int      @default(1)
  estado      String   @default("aprobada") // solicitada | aprobada | tomada
  nota        String   @default("")
  createdAt   DateTime @default(now())
}

model Incremento {
  id          Int      @id @default(autoincrement())
  empleadoId  Int
  empleado    Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  fecha       DateTime @default(now())
  sueldoNuevo Float    @default(0)
  porcentaje  Float    @default(0)
  nota        String   @default("")
}
